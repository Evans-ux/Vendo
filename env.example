# Environment variables for Vendo
# Copy this to .env and fill in your actual values for local development

# Database
DATABASE_URL=postgresql://user:password@host:5432/vendo
DIRECT_URL=postgresql://user:password@host:5432/vendo

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Flutterwave (test mode)
FLW_MODE=test
FLW_SECRET_KEY_TEST=your-flutterwave-test-secret
NEXT_PUBLIC_FLW_PUBLIC_KEY_TEST=your-flutterwave-public-key
FLW_ENCRYPTION_KEY_TEST=your-flutterwave-encryption-key
FLW_WEBHOOK_HASH=your-webhook-hash

# Sendbox
SENDBOX_API_KEY=your-sendbox-api-key
SENDBOX_WEBHOOK_SECRET=your-sendbox-webhook-secret
SENDBOX_ACCESS_TOKEN=your-sendbox-access-token
SENDBOX_REFRESH_TOKEN=your-sendbox-refresh-token
SENDBOX_CLIENT_SECRETE=your-sendbox-client-secret

# CJ Dropshipping
CJ_API_KEY=your-cj-api-key

# AI Services
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key
HF_API_KEY=your-huggingface-api-key
OPENAI_API_KEY=your-openai-api-key
OLLAMA_API_KEY=your-ollama-api-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_LINK=your-telegram-bot-link

# Site
NEXT_PUBLIC_SITE_URL=https://vendo.com.ng

# Internal secrets (change in production)
INTERNAL_API_SECRET=your-internal-api-secret
CRON_SECRET=your-cron-secret
