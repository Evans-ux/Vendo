// Vee AI — Prisma Schema
// Stack: Next.js 15 + Supabase PostgreSQL + Prisma 7
// All UUIDs are generated by Postgres (gen_random_uuid()) not the app layer

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  CUSTOMER // default — someone shopping via Telegram/WhatsApp
  SUPPLIER // a vendor who has started or completed onboarding
  ADMIN // platform owner — full dashboard access
}

enum SupplierType {
  LOCAL // ships products themselves, faster delivery (2–3 days)
  DROPSHIP // third-party fulfillment, slower delivery (14–21 days)
}

enum DeliveryMethod {
  SELF_DELIVERY // LOCAL suppliers handle their own delivery (own waybill)
  PLATFORM_LOGISTICS // LOCAL suppliers pay platform to handle delivery
  DROPSHIP_HANDLED // DROPSHIP suppliers handle everything via API
}

enum LogisticsProvider {
  SELF      // supplier handles own waybill
  SENDBOX   // Vendo-managed Sendbox shipment (LOCAL + PLATFORM_LOGISTICS)
  CJ        // CJ Dropshipping (DROPSHIP products)
}

enum KycStatus {
  PENDING // submitted, waiting for admin review
  APPROVED // admin verified the supplier's identity/business
  REJECTED // admin rejected — supplier must re-submit
}

enum OnboardingStep {
  NOT_STARTED // just registered, hasn't touched onboarding
  PROFILE_COMPLETE // filled business name, phone, state, type
  KYC_SUBMITTED // uploaded identity/CAC document
  FIRST_PRODUCT // suppliers first product 
  TERMS_ACCEPTED// agreed to our terms and conditions
  COMPLETED // admin approved — supplier is live
}

enum OrderStatus {
  PENDING // order placed, awaiting confirmation
  CONFIRMED // supplier confirmed the order
  SHIPPED // item dispatched
  DELIVERED // customer received
  CANCELLED // cancelled by customer or supplier
}

enum PaymentStatus {
  UNPAID // payment link sent but not paid
  PAID // Flutterwave confirmed payment
  REFUNDED // payment reversed
}

// ─────────────────────────────────────────────
// USER
// The base identity record. Created by your co-coder's auth flow.
// Supabase Auth manages the session; this table stores app-level data.
// ─────────────────────────────────────────────

model User {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Core identity — set during signup
  email String  @unique
  name  String?

  // Role gates what the user can access
  // CUSTOMER by default; becomes SUPPLIER after onboarding is approved
  role UserRole @default(CUSTOMER)

  // Telegram bot linking — set when user first messages the bot
  // Unique because one Telegram account = one Vee AI account
  telegramId String? @unique

  // Phone number — collected during supplier onboarding or customer checkout
  phone String?

  // Size profile — AI uses these to recommend sizes automatically
  // Stored here so the Telegram bot can access them without a separate lookup
  shoeSize  String? // e.g. "42", "43", "UK 9"
  shirtSize String? // e.g. "M", "L", "XL"

  // Delivery coordinates — saved when customer shares location via Telegram
  lat Decimal? @db.Decimal(10, 7)
  lng Decimal? @db.Decimal(10, 7)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations
  supplier Supplier? // one user can have at most one supplier profile
  orders   Order[] // all orders placed by this user as a customer
}

// ─────────────────────────────────────────────
// SUPPLIER
// Created when a user starts the onboarding flow.
// Separate from User so a supplier's business data is cleanly isolated.
// ─────────────────────────────────────────────

model Supplier {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // One-to-one link back to the User who owns this supplier profile
  userId String @unique @db.Uuid

  // Business identity
  businessName String // official store name shown to customers
  phone        String // business contact (may differ from user phone)
  address      String? // physical address — required for LOCAL, optional for DROPSHIP
  state        String? // Nigerian state — used for delivery time estimates

  // LOCAL = ships themselves (2–3 day delivery shown to customers)
  // DROPSHIP = third-party ships (14–21 day delivery shown to customers)
  supplierType SupplierType @default(LOCAL)

  // KYC — Know Your Customer / Know Your Business
  // This is the identity verification gate before a supplier goes live.
  // kycStatus tracks where the admin review is.
  // kycDocUrl is the Supabase Storage URL of the uploaded document.
  // kycDocType tells admin what kind of document was submitted.
  // kycRejectionReason is filled by admin when they reject — supplier sees this message.
  // kycSubmittedAt timestamps when the doc was uploaded (for admin queue ordering).
  // kycReviewedAt timestamps when admin made a decision.
  kycStatus          KycStatus @default(PENDING)
  kycDocUrl          String? // private Supabase Storage URL (kyc-documents bucket) - ID Document
  kycDocType         String? // "NIN" | "BVN" | "Passport" | "Driver's License"
  kycRejectionReason String? // admin fills this when rejecting — shown to supplier
  kycSubmittedAt     DateTime? // when supplier uploaded the doc
  kycReviewedAt      DateTime? // when admin approved or rejected

  // Business Verification (NEW - Step 2)
  // Supplier must upload ONE of: CAC Document OR Bank Statement
  businessDocUrl  String? // Supabase Storage URL for CAC or Bank Statement
  businessDocType String? // "CAC" | "BANK_STATEMENT"

  // Bank Account Details — Required for payout processing
  // Verified via Flutterwave account resolution during KYC
  bankName          String? // e.g., "GTBank", "Access Bank"
  bankCode          String? // Flutterwave bank code e.g. "058" for GTBank
  accountNumber     String? // 10-digit NUBAN account number
  accountHolderName String? // Flutterwave-verified account name

  // Flutterwave subaccount ID — created when KYC is approved
  // Used for automatic split payments (supplier gets 90%, platform keeps 10%)
  flwSubaccountId   String?

  // ── Wallet & Payouts ──────────────────────────────────────────────────────
  // walletBalance = accumulated earnings not yet withdrawn
  // Credited when an order is marked DELIVERED (basePrice amount)
  // Debited when supplier requests a withdrawal
  walletBalance Decimal @default(0) @db.Decimal(12, 2)

  // withdrawalPin = bcrypt hash of the supplier's 4-digit PIN
  // Required to authorise any withdrawal request
  // Null = PIN not yet set (supplier must set it from Settings before withdrawing)
  withdrawalPin String?

  // totalEarned = lifetime earnings (never decremented — audit trail)
  totalEarned Decimal @default(0) @db.Decimal(12, 2)

  // Onboarding progress — drives the multi-step UI
  // NOT_STARTED → PROFILE_COMPLETE → KYC_SUBMITTED → COMPLETED
  onboardingStep OnboardingStep @default(NOT_STARTED)

  // Store branding
  logoUrl        String? // Supabase Storage URL (product-images bucket)
  storeBannerUrl String? // Supabase Storage URL for the store banner
  bio            String? // short store description shown on supplier profile

  // isActive is only true after admin sets kycStatus to APPROVED
  // Products from inactive suppliers are hidden from the Telegram bot
  isActive Boolean @default(false)

  // Terms & Conditions — supplier must accept before accessing their dashboard
  // Null means not yet accepted. Timestamp is stored for legal audit trail.
  termsAcceptedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user     User      @relation(fields: [userId], references: [id])
  products Product[]
  earnings EarningsTransaction[]
  withdrawals WithdrawalRequest[]
}

// ─────────────────────────────────────────────
// PRODUCT
// Uploaded by supplier. Hidden until admin approves.
// ─────────────────────────────────────────────

model Product {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplierId String @db.Uuid

  name        String
  description String?
  category    String? // "Footwear" | "Tops" | "Bottoms" | "Accessories" etc.

  // Pricing — supplier sets basePrice, sellingPrice is auto-calculated
  // sellingPrice = ROUND(basePrice * 1.25) — enforced in the API route, stored here
  basePrice    Decimal @db.Decimal(10, 2)
  sellingPrice Decimal @db.Decimal(10, 2)

  // Images — array of Supabase Storage URLs (product-images bucket)
  // First URL in the array is treated as the primary/thumbnail image
  imageUrls String[]

  // Sizes stored as JSON for flexibility across product types
  // Footwear: {"available": ["40","41","42","43","44"]}
  // Clothing:  {"available": ["XS","S","M","L","XL","XXL"]}
  sizes Json

  stock Int @default(0)

  // Delivery Method (for LOCAL suppliers only)
  // SELF_DELIVERY = supplier uses own waybill, handles delivery themselves (FREE for supplier)
  // PLATFORM_LOGISTICS = platform handles delivery, supplier pays logistics fee per order
  // DROPSHIP_HANDLED = for DROPSHIP products (API integration, handled by third party)
  deliveryMethod DeliveryMethod @default(SELF_DELIVERY)

  // Logistics Fee (for PLATFORM_LOGISTICS products)
  // The fee supplier pays per order for this specific product
  // Example: 1500 (₦1,500 per delivery)
  // Shown to supplier before they choose PLATFORM_LOGISTICS
  logisticsFee Decimal? @db.Decimal(10, 2)
  // Sendbox courier identifier for PLATFORM_LOGISTICS
  courierId String? // optional courier ID from Sendbox

  // Admin must approve before product appears in Telegram bot search
  isApproved Boolean @default(true)

  // Supplier can toggle this off to temporarily hide a product
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  supplier   Supplier    @relation(fields: [supplierId], references: [id])
  orderItems OrderItem[]
}

// ─────────────────────────────────────────────
// ORDER + ORDER ITEM
// Order = the basket. OrderItem = each product line inside it.
// Split so one order can contain multiple products from multiple suppliers.
// ─────────────────────────────────────────────

model Order {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @db.Uuid

  // Human-readable order number — generated at creation time
  orderNumber String @unique @default("")

  totalAmount Decimal     @db.Decimal(10, 2)
  status      OrderStatus @default(PENDING)

  // Flutterwave
  paymentRef    String? // transaction reference from Flutterwave webhook
  paymentStatus PaymentStatus @default(UNPAID)

  // Delivery
  trackingNumber  String?
  deliveryAddress String?
  lat             Decimal? @db.Decimal(10, 7) // from Google Maps location share
  lng             Decimal? @db.Decimal(10, 7)

  // Logistics integration
  // logisticsProvider tells us which system is handling this order's delivery
  // sendboxShipmentId is the Sendbox shipment reference (for SENDBOX orders)
  // cjOrderId is the CJ Dropshipping order reference (for CJ orders)
  // courierName is the human-readable courier name e.g. "GIG Logistics", "DHL"
  // logisticsStatus is the raw status string from the provider webhook
  logisticsProvider  LogisticsProvider @default(SELF)
  sendboxShipmentId  String? // Sendbox shipment ID — used to fetch tracking
  cjOrderId          String? // CJ order ID — used to poll/receive status
  courierName        String? // e.g. "GIG Logistics", "Kwik", "DHL"
  logisticsStatus    String? // raw status from provider: "picked_up", "in_transit" etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]
}

model OrderItem {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String @db.Uuid
  productId String @db.Uuid

  quantity  Int
  size      String? // the size the customer selected
  unitPrice Decimal @db.Decimal(10, 2) // sellingPrice snapshot at time of order

  // Relations
  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

// ─────────────────────────────────────────────
// EARNINGS TRANSACTION
// Immutable ledger entry created when an order is confirmed DELIVERED.
// type CREDIT = earnings added to wallet (customer confirmed delivery)
// type DEBIT  = earnings removed from wallet (withdrawal processed)
// ─────────────────────────────────────────────

enum EarningsType {
  CREDIT  // order delivered — earnings credited to wallet
  DEBIT   // withdrawal processed — earnings debited from wallet
}

enum EarningsStatus {
  PENDING   // order delivered but 24hr dispute window not yet passed
  AVAILABLE // cleared — can be withdrawn
  WITHDRAWN // already paid out via Flutterwave transfer
}

model EarningsTransaction {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplierId String @db.Uuid

  type   EarningsType
  status EarningsStatus @default(PENDING)

  amount      Decimal @db.Decimal(12, 2) // basePrice amount (after 10% commission deducted)
  description String  // e.g. "Order #VND-001 delivered"

  // Link back to the order that generated this earning (null for debits)
  orderId String? @db.Uuid

  // When PENDING → AVAILABLE (24hrs after delivery confirmation)
  availableAt DateTime?

  createdAt DateTime @default(now())

  // Relations
  supplier Supplier @relation(fields: [supplierId], references: [id])
}

// ─────────────────────────────────────────────
// WITHDRAWAL REQUEST
// Created when supplier requests a payout.
// Flutterwave transfer is initiated on creation.
// ─────────────────────────────────────────────

enum WithdrawalStatus {
  PROCESSING  // Flutterwave transfer initiated
  COMPLETED   // Transfer confirmed successful
  FAILED      // Transfer failed — wallet balance restored
}

model WithdrawalRequest {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplierId String @db.Uuid

  amount    Decimal          @db.Decimal(12, 2)
  status    WithdrawalStatus @default(PROCESSING)

  // Flutterwave transfer reference
  flwTransferId  String? // Flutterwave transfer ID
  flwReference   String? // our reference sent to Flutterwave

  // Payout destination snapshot (in case supplier changes bank later)
  bankName          String
  bankCode          String
  accountNumber     String
  accountHolderName String

  failureReason String? // filled if status = FAILED

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  // Relations
  supplier Supplier @relation(fields: [supplierId], references: [id])
}
