generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String    @unique
  name       String?
  createdAt  DateTime  @default(now())
  lat        Decimal?  @db.Decimal(10, 7)
  lng        Decimal?  @db.Decimal(10, 7)
  phone      String?
  role       UserRole  @default(CUSTOMER)
  shirtSize  String?
  shoeSize   String?
  telegramId String?   @unique
  updatedAt  DateTime  @default(now()) @updatedAt
  orders     Order[]
  supplier   Supplier?
}

model Supplier {
  id                 String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String                @unique @db.Uuid
  businessName       String
  phone              String
  address            String?
  state              String?
  supplierType       SupplierType          @default(LOCAL)
  kycStatus          KycStatus             @default(PENDING)
  kycDocUrl          String?
  kycDocType         String?
  kycRejectionReason String?
  kycSubmittedAt     DateTime?
  kycReviewedAt      DateTime?
  onboardingStep     OnboardingStep        @default(NOT_STARTED)
  logoUrl            String?
  bio                String?
  isActive           Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  storeBannerUrl     String?
  termsAcceptedAt    DateTime?
  accountHolderName  String?
  accountNumber      String?
  bankName           String?
  businessDocType    String?
  businessDocUrl     String?
  bankCode           String?
  totalEarned        Decimal               @default(0) @db.Decimal(12, 2)
  walletBalance      Decimal               @default(0) @db.Decimal(12, 2)
  withdrawalPin      String?
  flwSubaccountId    String?
  // Pickup address — used by Sendbox for shipment collection
  // Separate from `address` (business address) so suppliers can specify
  // exactly where couriers should collect orders from.
  pickupAddress      String?   // street / full address line
  pickupCity         String?   // city e.g. "Onitsha"
  pickupState        String?   // state e.g. "Anambra" (overrides `state` for logistics)
  pickupPostCode     String?   // postal code e.g. "434101"
  pickupPhone        String?   // contact phone at pickup location
  // PIN change OTP — 6-digit code emailed before allowing PIN change
  // Cleared after use or expiry
  pinOtp          String?   // bcrypt hash of the 6-digit OTP
  pinOtpExpiresAt DateTime? // OTP expires 10 minutes after issue
  earnings           EarningsTransaction[]
  products           Product[]
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawals        WithdrawalRequest[]
  notifications      Notification[]
  deleteRequests     DeleteRequest[]
}

model Product {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplierId     String         @db.Uuid
  name           String
  description    String?
  category       String?
  basePrice      Decimal        @db.Decimal(10, 2)
  sellingPrice   Decimal        @db.Decimal(10, 2)
  imageUrls      String[]
  sizes          Json
  stock          Int            @default(0)
  isApproved     Boolean        @default(true)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deliveryMethod DeliveryMethod @default(SELF_DELIVERY)
  logisticsFee   Decimal?       @db.Decimal(10, 2)
  courierId      String?
  isDeleted      Boolean        @default(false)
  orderItems     OrderItem[]
  supplier       Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  deleteRequests DeleteRequest[]
}

model Order {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String            @db.Uuid
  totalAmount       Decimal           @db.Decimal(10, 2)
  status            OrderStatus       @default(PENDING)
  paymentRef        String?
  paymentStatus     PaymentStatus     @default(UNPAID)
  trackingNumber    String?
  deliveryAddress   String?
  lat               Decimal?          @db.Decimal(10, 7)
  lng               Decimal?          @db.Decimal(10, 7)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  cjOrderId         String?
  courierName       String?
  logisticsProvider LogisticsProvider @default(SELF)
  logisticsStatus   String?
  sendboxShipmentId String?
  orderNumber       String            @unique @default("")
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items             OrderItem[]
}

model OrderItem {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String  @db.Uuid
  productId String  @db.Uuid
  quantity  Int
  size      String?
  unitPrice Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model EarningsTransaction {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplierId  String         @db.Uuid
  type        EarningsType
  status      EarningsStatus @default(PENDING)
  amount      Decimal        @db.Decimal(12, 2)
  description String
  orderId     String?        @db.Uuid
  availableAt DateTime?
  createdAt   DateTime       @default(now())
  supplier    Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model WithdrawalRequest {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplierId        String           @db.Uuid
  amount            Decimal          @db.Decimal(12, 2)
  status            WithdrawalStatus @default(PROCESSING)
  flwTransferId     String?
  flwReference      String?
  bankName          String
  bankCode          String
  accountNumber     String
  accountHolderName String
  failureReason     String?
  createdAt         DateTime         @default(now())
  completedAt       DateTime?
  supplier          Supplier         @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

enum UserRole {
  CUSTOMER
  SUPPLIER
  ADMIN
}

enum SupplierType {
  LOCAL
  DROPSHIP
}

enum DeliveryMethod {
  SELF_DELIVERY
  PLATFORM_LOGISTICS
  DROPSHIP_HANDLED
}

enum LogisticsProvider {
  SELF
  SENDBOX
  CJ
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OnboardingStep {
  NOT_STARTED
  PROFILE_COMPLETE
  KYC_SUBMITTED
  COMPLETED
  FIRST_PRODUCT
  TERMS_ACCEPTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum EarningsType {
  CREDIT
  DEBIT
}

enum EarningsStatus {
  PENDING
  AVAILABLE
  WITHDRAWN
}

enum WithdrawalStatus {
  PROCESSING
  COMPLETED
  FAILED
}

// ─────────────────────────────────────────────
// NOTIFICATION
// Admin → Supplier (targeted) or Admin → All Suppliers (broadcast)
// ─────────────────────────────────────────────

enum NotificationTarget {
  SUPPLIER   // sent to one specific supplier
  ALL        // broadcast to all suppliers
}

model Notification {
  id         String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // null = broadcast to ALL suppliers
  supplierId String?            @db.Uuid
  target     NotificationTarget @default(SUPPLIER)
  title      String
  message    String
  hasRead    Boolean            @default(false)
  createdAt  DateTime           @default(now())

  supplier   Supplier?          @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// DELETE REQUEST
// Supplier requests deletion of a product that has order history.
// Admin reviews and approves or rejects.
// ─────────────────────────────────────────────

enum DeleteRequestStatus {
  PENDING   // waiting for admin review
  APPROVED  // admin approved — product soft-deleted
  REJECTED  // admin rejected — product stays live
}

model DeleteRequest {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId  String              @db.Uuid
  supplierId String              @db.Uuid
  reason     String              // supplier's reason for wanting to delete
  status     DeleteRequestStatus @default(PENDING)
  adminNote  String?             // admin's rejection reason (if rejected)
  createdAt  DateTime            @default(now())
  reviewedAt DateTime?

  product    Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier   Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}
